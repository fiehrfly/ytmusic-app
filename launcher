#!/bin/bash
# YouTube Music — an UNOFFICIAL, Chromium-based desktop app.
#
# Runs its OWN Chromium engine, branded "YouTube Music" with its own identity + icon, so it
# appears as its own app in Cmd+Tab / the Dock — never grouped with Google Chrome — and works
# whether or not the user has Chrome installed. The engine is materialized once into
# Application Support (reused from a local Chromium if present, else downloaded per-arch),
# kept current by a daily background update check, and launched single-instance + hard-locked.
set -u

SELF="${BASH_SOURCE[0]:-$0}"
MACOS_DIR="$(cd "$(dirname "$SELF")" && pwd)"
RES_DIR="$(cd "$MACOS_DIR/../Resources" && pwd)"

SUPPORT="$HOME/Library/Application Support/YouTube Music"
PROFILE="$SUPPORT/profile"
ENGINE_DIR="$SUPPORT/Engine"
ENGINE_APP="$ENGINE_DIR/YouTube Music.app"
PENDING_APP="$ENGINE_DIR/YouTube Music.pending.app"
ENGINE_BIN="$ENGINE_APP/Contents/MacOS/Google Chrome for Testing"
ENGINE_ID="com.marvincolcol.youtubemusic.engine"
STAMP="$ENGINE_DIR/.last_update_check"
CFT_PINNED="148.0.7778.96"          # known-good fallback version
TARGET="https://music.youtube.com/"
mkdir -p "$PROFILE" "$ENGINE_DIR"

LOG_DIR="$HOME/Library/Logs"; mkdir -p "$LOG_DIR"; LOG="$LOG_DIR/YouTube Music.log"
[ -f "$LOG" ] && [ "$(/usr/bin/stat -f%z "$LOG" 2>/dev/null || echo 0)" -gt 1048576 ] && : > "$LOG"
echo "[$(/bin/date '+%Y-%m-%d %H:%M:%S')] launch" >> "$LOG"
dialog(){ /usr/bin/osascript -e "display dialog \"$1\" buttons {\"OK\"} default button 1 with title \"YouTube Music\" with icon caution" >/dev/null 2>&1; }
notify(){ /usr/bin/osascript -e "display notification \"$1\" with title \"YouTube Music\"" >/dev/null 2>&1; }

# (5) Single instance: if it's already running, just bring it to front — no new window.
if /usr/bin/pgrep -f "user-data-dir=$PROFILE" >/dev/null 2>&1; then
  echo "[reopen] already running -> activating existing window" >> "$LOG"
  /usr/bin/osascript -e "tell application id \"$ENGINE_ID\" to activate" >/dev/null 2>&1
  exit 0
fi

# (4) Apply a pending engine update staged by a previous background check.
if [ -d "$PENDING_APP" ] && [ -x "$PENDING_APP/Contents/MacOS/Google Chrome for Testing" ]; then
  echo "[update] applying staged engine update" >> "$LOG"
  rm -rf "$ENGINE_APP"; mv "$PENDING_APP" "$ENGINE_APP"
fi

if [ "$(/usr/sbin/sysctl -n hw.optional.arm64 2>/dev/null)" = "1" ]; then PLAT="mac-arm64"; else PLAT="mac-x64"; fi

# Build a branded engine at $1 (.app). $2 = version to download; $3 = "reuse" to allow
# cloning a local Chromium instead of downloading. Returns 0 on success.
materialize() {
  local DEST="$1" VER="$2" REUSE="${3:-}" TMP SRC
  TMP="$(/usr/bin/mktemp -d /tmp/ytm.XXXXXX)" || return 1
  SRC=""
  if [ "$REUSE" = "reuse" ]; then
    SRC="$(/bin/ls -d "$HOME/Library/Caches/ms-playwright"/chromium-*/chrome-mac*/"Google Chrome for Testing.app" 2>/dev/null | /usr/bin/head -1)"
  fi
  if [ -n "$SRC" ] && [ -d "$SRC" ]; then
    echo "[engine] cloning local Chromium: $SRC" >> "$LOG"
    cp -c -R "$SRC" "$TMP/E.app" 2>/dev/null || cp -R "$SRC" "$TMP/E.app"   # (3) APFS clone (slim); fallback to copy
  else
    local URL="https://storage.googleapis.com/chrome-for-testing-public/$VER/$PLAT/chrome-$PLAT.zip"
    echo "[engine] downloading $URL" >> "$LOG"
    /usr/bin/curl -fsSL "$URL" -o "$TMP/cft.zip" || { rm -rf "$TMP"; return 1; }
    /usr/bin/unzip -q "$TMP/cft.zip" -d "$TMP" || { rm -rf "$TMP"; return 1; }
    mv "$TMP/chrome-$PLAT/Google Chrome for Testing.app" "$TMP/E.app" || { rm -rf "$TMP"; return 1; }
  fi
  local PB=/usr/libexec/PlistBuddy PL="$TMP/E.app/Contents/Info.plist"
  $PB -c "Set :CFBundleIdentifier $ENGINE_ID" "$PL" 2>/dev/null
  $PB -c "Set :CFBundleName YouTube Music" "$PL" 2>/dev/null
  $PB -c "Set :CFBundleDisplayName YouTube Music" "$PL" 2>/dev/null
  [ -f "$RES_DIR/app.icns" ] && cp "$RES_DIR/app.icns" "$TMP/E.app/Contents/Resources/ytmusic.icns" \
    && $PB -c "Set :CFBundleIconFile ytmusic" "$PL" 2>/dev/null
  /usr/bin/codesign --force --deep --sign - "$TMP/E.app" >/dev/null 2>&1
  rm -rf "$DEST"; mv "$TMP/E.app" "$DEST"; rm -rf "$TMP"
  [ -x "$DEST/Contents/MacOS/Google Chrome for Testing" ]
}

# First run: materialize the engine (reuse a local Chromium if present, else download).
if [ ! -x "$ENGINE_BIN" ]; then
  echo "[setup] first-run engine setup ($PLAT)" >> "$LOG"
  notify "Setting up YouTube Music (one-time)…"
  if ! materialize "$ENGINE_APP" "$CFT_PINNED" reuse; then
    dialog "Couldn't set up the YouTube Music engine. Check your internet connection and reopen.\n\nLog: $LOG"
    exit 1
  fi
  echo "[setup] engine ready" >> "$LOG"
  : > "$STAMP"   # defer the daily update check ~24h so first run doesn't immediately re-download
fi

# (4) Background, at most once a day: if a newer stable Chromium exists, stage it for next launch.
NOW="$(/bin/date +%s)"; LAST="$(/usr/bin/stat -f%m "$STAMP" 2>/dev/null || echo 0)"
if [ "$((NOW - LAST))" -gt 86400 ]; then
  : > "$STAMP"
  (
    LATEST="$(/usr/bin/curl -fsSL https://googlechromelabs.github.io/chrome-for-testing/LATEST_RELEASE_STABLE 2>/dev/null)"
    INSTALLED="$(/usr/libexec/PlistBuddy -c 'Print :CFBundleShortVersionString' "$ENGINE_APP/Contents/Info.plist" 2>/dev/null)"
    if [ -n "$LATEST" ] && [ -n "$INSTALLED" ] && [ "$LATEST" != "$INSTALLED" ] && [ ! -d "$PENDING_APP" ]; then
      newest="$(printf '%s\n%s\n' "$LATEST" "$INSTALLED" | /usr/bin/sort -V | /usr/bin/tail -1)"
      if [ "$newest" = "$LATEST" ]; then
        echo "[update] newer engine $LATEST (have $INSTALLED) -> staging" >> "$LOG"
        materialize "$PENDING_APP" "$LATEST" || rm -rf "$PENDING_APP"
      fi
    fi
  ) >/dev/null 2>&1 &
fi

# Launch the branded engine via LaunchServices (NOT exec), so this launcher exits and a later
# relaunch re-runs it → the single-instance guard above catches it (no new window) instead of a
# reopen hitting the engine directly. Shared flags: media keys (HardwareMediaKeyHandling) and the
# lean/hardened set (no extensions/themes/sync/pings/background net; one renderer; capped cache;
# sandbox ON).
#
# Default = windowed app (--app): dedicated window, no address bar, no tab strip.
# HARD-LOCK = kiosk: run `touch "$SUPPORT/.kiosk"` to fully block Cmd+N / Cmd+T. NOTE: kiosk is
# FULLSCREEN (no movable/floating window), trading away easy windowed switching. `rm` the file to revert.
COMMON=( --user-data-dir="$PROFILE" --no-first-run --no-default-browser-check
  --disable-extensions --disable-sync --disable-background-networking --disable-default-apps
  --disable-breakpad --no-pings --process-per-site --disk-cache-size=104857600
  --disable-features=Translate --disable-infobars --enable-features=HardwareMediaKeyHandling )
if [ -f "$SUPPORT/.kiosk" ]; then
  echo "[run] open -n engine (kiosk)" >> "$LOG"
  exec /usr/bin/open -n "$ENGINE_APP" --args --kiosk "${COMMON[@]}" "$TARGET"
else
  echo "[run] open -n engine (windowed)" >> "$LOG"
  exec /usr/bin/open -n "$ENGINE_APP" --args --app="$TARGET" "${COMMON[@]}"
fi
