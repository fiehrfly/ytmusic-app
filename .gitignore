# Build artifact — regenerated by build.sh
YouTube Music.app/

# Distributable produced by package.sh
dist/
*.zip

# Node deps — bundled into the .app at build time, never source
node_modules/

# Logs
*.log

# Tooling / index databases (ruflo, ruvector, etc.)
*.db

# Icon build scratch
.iconset/

# DMG build scratch (the .dmg lands in dist/, already ignored above)
.dmg-stage/
.dmg-rw.dmg
# Intermediate background renders — the committed dmg-background.tiff/.svg are the sources
dmg-background.png
dmg-background@2x.png

# macOS cruft
.DS_Store
